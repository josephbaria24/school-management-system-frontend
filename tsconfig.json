{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-dev-*/types/**/*.ts",
    ".next-dev-3001/types/**/*.ts",
    ".next-dev-3003/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-dev-3004/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowJs": true,
    "strict": false,
    "incremental": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "target": "ES2017",
    "skipLibCheck": true,
    "module": "esnext",
    "isolatedModules": true
  }
}
